PORT=5000

# URL database PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/database_name"

# Secret key untuk better-auth (gunakan string acak yang panjang)
BETTER_AUTH_SECRET="ganti-dengan-secret-key-yang-aman"

# URL backend (sesuaikan dengan domain deploy)
BETTER_AUTH_URL="http://localhost:5000"

# URL frontend yang diizinkan CORS (pisahkan dengan koma jika lebih dari satu)
# Contoh production: CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN="http://localhost:5173"
